      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "zundo": "^2.1.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
