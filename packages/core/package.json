{
  "name": "@blustar/core",
  "version": "0.1.0",
  "description": "Blustar — núcleo do produto: modelo de dados, store (Zustand) e base de undo/redo.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
