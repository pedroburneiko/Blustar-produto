{
  "name": "blustar-produto",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo do produto BluStar — design system, tokens e apps.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:tokens": "pnpm --filter @blustar/tokens build",
    "build:ui": "pnpm --filter @blustar/ui build",
    "build:workspace": "pnpm --filter @blustar/workspace build",
    "dev:workspace": "pnpm --filter @blustar/workspace dev",
    "storybook": "pnpm --filter @blustar/ui storybook",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
